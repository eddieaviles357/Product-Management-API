{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api.productmanagement.com/v1/registerUser.schema.json",
  "title": "RegisterUser",
  "description": "Adds new user",
  "type": "object",
  "properties": {
    "firstName": {
      "description": "first name",
      "type": "string",
      "minLength": 1,
      "maxLength": 30
    },
    "lastName": {
      "description": "last name",
      "type": "string",
      "minLength": 1,
      "maxLength": 30
    },
    "username": {
      "description": "unique username",
      "type": "string",
      "minLength": 1,
      "maxLength": 20
    },
    "password": {
      "description": "password",
      "type": "string",
      "minLength": 8,
      "maxLength": 60
    },
    "email": {
      "description": "email",
      "type": "string",
      "format": "email",
      "minLength": 5,
      "maxLength": 254
    }
  },
  "additionalProperties": false,
  "required": ["firstName", "lastName", "username", "password", "email"]
}